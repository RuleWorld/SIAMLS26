begin molecule types
  IL10(il10r1)
  IL10R1(il10,il10r2,jak1,stat)
  IL10R2(il10r1)
  JAK1(rec,socs1)
  PTP1()
  PTP3()
  SOCS1(jak1)
  STAT1(Y~0~P)
  STAT3(Y~0~P)
end molecule types

begin species
  IL10(il10r1) IL10_0
  IL10R1(il10,il10r2,jak1,stat) IL10R1_0
  IL10R2(il10r1) IL10R2_0
  JAK1(rec,socs1) JAK1_0
  SOCS1(jak1) SOCS1_0
  PTP3() PTP3_0
  PTP1() PTP1_0
